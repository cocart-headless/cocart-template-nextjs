# CoCart Store
NEXT_PUBLIC_COCART_STORE_URL={{COCART_STORE_URL}}
NEXT_PUBLIC_COCART_STORE_HOSTNAME=   # extracted from COCART_STORE_URL (e.g. my-shop.com)

# WordPress (for blog/pages — may be the same as your store)
NEXT_PUBLIC_WORDPRESS_URL={{WORDPRESS_URL}}
NEXT_PUBLIC_WORDPRESS_HOSTNAME=      # extracted from WORDPRESS_URL (e.g. my-shop.com)
